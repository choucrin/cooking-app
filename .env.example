# このファイルをコピーして .env.local を作成し、値を設定してください。
# cp .env.example .env.local
#
# 値はすべて Firebase Console > プロジェクトの設定 > 全般 > マイアプリ の
# 「SDK の設定と構成」から取得できます（Web アプリを1つ追加してください）。
# これらはブラウザに埋め込まれる公開設定値であり、機密情報ではありません。
# 実際のアクセス制御は Firestore セキュリティルール（firestore.rules）と
# Firebase Authentication が担います。

NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""

# GitHub Pages のプロジェクトサイト（https://<user>.github.io/<repo>/）で動作確認する場合のみ設定。
# ローカル開発 (npm run dev) では空のままで構いません。
NEXT_PUBLIC_BASE_PATH=""
