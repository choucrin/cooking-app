# このファイルをコピーして .env.local を作成し、値を設定してください。
# cp .env.example .env.local

# PostgreSQL 接続文字列（README.md の「データベースのセットアップ」を参照）
# 例: postgres://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=""

# Anthropic (Claude) API キー。https://console.anthropic.com/ で発行します。
ANTHROPIC_API_KEY=""

# 使用するClaudeモデル（省略可。未設定時は claude-sonnet-5 を使用）
ANTHROPIC_MODEL="claude-sonnet-5"

# アプリ全体にかける簡易パスワード認証（第三者にURLが知られてもAPI利用枠を消費されないようにする）
# 十分に推測されにくい文字列を設定してください。この値を変更すると発行済みの全セッションが無効化されます。
APP_PASSWORD=""
