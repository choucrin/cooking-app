// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum IngredientCategory {
  VEGETABLE // 野菜
  FRUIT // 果物
  MEAT // 肉
  DAIRY_EGG // 卵・乳製品
  OTHER // その他
  SEASONING // 調味料
}

model Ingredient {
  id        String             @id @default(cuid())
  name      String
  category  IngredientCategory
  stock     Int                @default(0)
  // 在庫がなくても「買い足し可」であれば提案時の食材選択に表示する
  canBuy    Boolean            @default(false)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@index([category])
}

model Recipe {
  id     String @id @default(cuid())
  title  String
  // [{ "name": "豚肉", "amount": "200g" }, ...] 形式で保存
  ingredients     Json
  // 検索用に材料名だけを平坦化した配列も保持する
  ingredientNames String[]
  instructions    String    @db.Text
  // { "calories": 480, "protein": 22, "fat": 18, "carbohydrates": 55, "salt": 2.8 } 形式（1人分の目安）
  nutrition       Json      @default("{}")
  // 実際に作った日付。カレンダー表示にはこの日付を使う
  cookedAt        DateTime  @default(now())
  createdAt       DateTime  @default(now())

  @@index([cookedAt])
}
